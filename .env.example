# Copy to `.env.local` and adjust. Only VITE_-prefixed vars reach the browser
# bundle, so never put secrets here.

# Origin/root of the AI Fitness Coach API (used by src/lib/api/http.ts). Leave
# empty for same-origin; in dev point it at the backend origin. Endpoint paths
# already include their own prefix (e.g. /v1/coach/ask), so DON'T add a path here.
# The backend defaults to http://localhost:3000 (and its CORS allows :5173).
VITE_API_BASE_URL=http://localhost:3000
